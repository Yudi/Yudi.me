---
import {
  Laptop2,
  Wrench,
  Languages,
  PenLine,
  Palette,
  MapPin,
  Utensils,
  BookOpenCheck,
  Gamepad2,
  Video,
} from "lucide-astro";

const hobbies = [
  {
    icon: Laptop2,
    title: "Administrador de sistemas",
    description:
      "Manter servidores e redes com foco em disponibilidade, privacidade e desempenho.",
  },
  {
    icon: Wrench,
    title: "Consultor de TI",
    description:
      "Fornecer orientação, suporte e soluções personalizadas de hardware e software.",
  },
  {
    icon: PenLine,
    title: "Redator técnico",
    description:
      "Criar documentação clara e concisa para melhorar a usabilidade de sistemas e softwares.",
  },
  {
    icon: Languages,
    title: "Tradutor e revisor",
    description:
      "Adaptar conteúdos entre idiomas, mantendo clareza e consistência.",
  },
  {
    icon: Palette,
    title: "Designer gráfico e modelador 3D",
    description:
      "Projetar interfaces, identidades visuais e explorar expressão criativa por meio de projetos 3D.",
  },
  {
    icon: Video,
    title: "Editor de vídeo",
    description:
      "Editar conteúdos multimídia para fins criativos, informativos e educacionais.",
  },
  {
    icon: MapPin,
    title: "Contribuidor de mapas",
    description:
      "Editar mapas e fornecer feedback para melhorar dados de localização e ferramentas de navegação.",
  },
  {
    icon: Utensils,
    title: "Blogueiro de gastronomia",
    description:
      "Escrever e compartilhar experiências culinárias, avaliações e visões sobre a cultura gastronômica.",
  },
  {
    icon: BookOpenCheck,
    title: "Entusiasta de direito e história",
    description:
      "Explorar leis e preservar contextos históricos para compartilhar conhecimento.",
  },
  {
    icon: Gamepad2,
    title: "Gamer e amante de mídias",
    description: "Também gosto de jogos, livros e música.",
  },
];
---

<section class="py-10">
  <h2 class="mb-8 text-3xl">Hobbies</h2>
  <ul class="list rounded-box bg-base-100 shadow-sm">
    {
      hobbies.map(({ icon: Icon, title, description }) => (
        <li class="list-row items-start gap-4 border-b border-base-200 py-4 last:border-b-0 [grid-template-columns:auto_minmax(0,1fr)]">
          <div class="rounded-box bg-primary/10 text-primary flex size-11 shrink-0 items-center justify-center">
            <Icon class="h-5 w-5" aria-hidden="true" />
          </div>
          <div class="min-w-0">
            <h3 class="font-semibold">{title}</h3>
            <p class="mt-1 text-sm leading-relaxed opacity-75">
              {description}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
</section>
