---
import {
  Laptop2,
  Wrench,
  Languages,
  PenLine,
  Palette,
  MapPin,
  Utensils,
  BookOpenCheck,
  Gamepad2,
  Video,
} from "lucide-astro";

const hobbies = [
  {
    icon: Laptop2,
    title: "System Administrator",
    description:
      "Maintain servers and networks with a focus on uptime, security, and performance.",
  },
  {
    icon: Wrench,
    title: "IT Consultant",
    description:
      "Provide hardware and software guidance, support, and tailored solutions.",
  },
  {
    icon: PenLine,
    title: "Technical Writer",
    description:
      "Create clear and concise documentation to improve software and system usability.",
  },
  {
    icon: Languages,
    title: "Translator & Proofreader",
    description:
      "Adapt content across languages while maintaining clarity and consistency.",
  },
  {
    icon: Palette,
    title: "Graphic Designer & 3D Modeler",
    description:
      "Design interfaces, branding, and explore creative expression through 3D projects.",
  },
  {
    icon: Video,
    title: "Video Editor",
    description:
      "Edit multimedia content for creative, informational and educational purposes.",
  },
  {
    icon: MapPin,
    title: "Mapping Contributor",
    description:
      "Edit maps and contribute feedback to improve location data and navigation tools.",
  },
  {
    icon: Utensils,
    title: "Food Blogger",
    description:
      "Write and share culinary experiences, reviews, and insights on dining culture.",
  },
  {
    icon: BookOpenCheck,
    title: "Law & History Enthusiast",
    description:
      "Explore laws and preserve historical contexts to share knowledge.",
  },
  {
    icon: Gamepad2,
    title: "Gamer & Media Lover",
    description: "I also enjoy games, books, and music.",
  },
];
---

<section class="py-10">
  <h2 class="mb-8 text-3xl">Hobbies</h2>
  <ul class="list rounded-box bg-base-100 shadow-sm">
    {
      hobbies.map(({ icon: Icon, title, description }) => (
        <li class="list-row items-start gap-4 border-b border-base-200 py-4 last:border-b-0 [grid-template-columns:auto_minmax(0,1fr)]">
          <div class="rounded-box bg-primary/10 text-primary flex size-11 shrink-0 items-center justify-center">
            <Icon class="h-5 w-5" aria-hidden="true" />
          </div>
          <div class="min-w-0">
            <h3 class="font-semibold">{title}</h3>
            <p class="mt-1 text-sm leading-relaxed opacity-75">
              {description}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
</section>
